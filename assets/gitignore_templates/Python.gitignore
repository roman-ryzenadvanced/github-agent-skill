# Python .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.nyc_output/

# Jupyter
.ipynb_checkpoints/

# MyPy
.mypy_cache/
.dmypy.json

# Ruff
.ruff_cache/

# Database
*.db
*.sqlite3
